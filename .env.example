# Discord bot token generated in Discord Developer Portal.
DISCORD_TOKEN=PUT_YOUR_BOT_TOKEN_HERE

# Channel where public news will be posted.
NEWS_CHANNEL_ID=PUT_NEWS_CHANNEL_ID_HERE

# Private channel where source failures, blocks or parsing issues will be reported.
ADMIN_LOG_CHANNEL_ID=PUT_ADMIN_LOG_CHANNEL_ID_HERE

# Role to mention when a source fails or gets blocked.
ADMIN_ROLE_ID=PUT_ADMIN_ROLE_ID_HERE

# News mention mode: everyone | role | none
MENTION_MODE=everyone

# Required only when MENTION_MODE=role.
NEWS_ROLE_ID=

# Frequency to check sources. Recommended: 30 or 60.
POLL_INTERVAL_MINUTES=60

# Prevents spamming admins when one source keeps failing. 360 = one alert every 6 hours per source/error type.
ADMIN_ALERT_COOLDOWN_MINUTES=360

# Max number of new articles to publish per source on each cycle.
MAX_NEWS_PER_SOURCE=3

YUGIOH_NEWS_URL=https://www.yugioh-card.com/eu/es/noticias/
POKEMON_NEWS_URL=https://www.pokemon.com/el/noticias-pokemon

# Pokemon fallback source used when pokemon.com blocks or fails.
ENABLE_POKEMON_FALLBACK=true
POKEMON_FALLBACK_NEWS_URL=https://vandal.elespanol.com/noticias/noticias-sobre-pokemon

# If true, current articles found on startup are published. If false, they are only registered as known.
SEND_EXISTING_ON_START=false

# Local persistence file for sent news IDs. Keep it outside git.
SENT_NEWS_FILE=sent-news.json

# Optional HTTP timeout.
HTTP_TIMEOUT_MS=15000
